
@model MedTrackerScreensMVC.Models.Medication
<h2 class="mb-3">@Model.Name</h2>
<div class="card"><div class="card-body">
  <dl class="row mb-0">
    <dt class="col-sm-3">Dosage</dt><dd class="col-sm-9">@Model.DosageDisplay</dd>
    <dt class="col-sm-3">Frequency</dt><dd class="col-sm-9">@Model.Frequency</dd>
    <dt class="col-sm-3">Time</dt><dd class="col-sm-9">@Model.TimeOfDay</dd>
    <dt class="col-sm-3">Pills remaining</dt><dd class="col-sm-9">@Model.PillsRemaining</dd>
    <dt class="col-sm-3">Refill date</dt><dd class="col-sm-9">@Model.RefillDate</dd>
    <dt class="col-sm-3">Notes</dt><dd class="col-sm-9">@Model.Notes</dd>
  </dl>
</div></div>
<div class="mt-3"><a class="btn btn-outline-secondary" href="/Medications">Back</a></div>
