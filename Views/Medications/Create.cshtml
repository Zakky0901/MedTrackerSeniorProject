@model MedTrackerScreensMVC.Models.Medication
<h2 class="mb-3">Add Medication</h2>
<form method="post">
<div asp-validation-summary="ModelOnly" class="text-danger"></div>
<div class="mb-3"><label class="form-label">Name</label><input asp-for="Name" class="form-control" /></div>
<div class="row">
  <div class="col-md-4 mb-3"><label class="form-label">Dosage</label><input asp-for="DosageDisplay" class="form-control" placeholder="e.g., 50mg" /></div>
  <div class="col-md-4 mb-3"><label class="form-label">Frequency</label><input asp-for="Frequency" class="form-control" placeholder="daily" /></div>
  <div class="col-md-4 mb-3"><label class="form-label">Time (HH:mm)</label><input asp-for="TimeOfDay" class="form-control" placeholder="08:00" /></div>
</div>
<div class="row">
  <div class="col-md-6 mb-3"><label class="form-label">Pills remaining</label><input asp-for="PillsRemaining" class="form-control" /></div>
  <div class="col-md-6 mb-3"><label class="form-label">Refill date</label><input asp-for="RefillDate" type="date" class="form-control" /></div>
</div>
<div class="mb-3"><label class="form-label">Notes</label><textarea asp-for="Notes" class="form-control" rows="3"></textarea></div>
<div class="form-check mb-3"><input class="form-check-input" asp-for="IsActive" /><label class="form-check-label" asp-for="IsActive">Active</label></div>
<div class="d-flex gap-2"><button class="btn btn-primary" type="submit">Save</button><a href="/Medications" class="btn btn-outline-secondary">Cancel</a></div></form>
