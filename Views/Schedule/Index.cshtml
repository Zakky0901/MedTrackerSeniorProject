@model IEnumerable<MedTrackerScreensMVC.Models.Dose>
@{ var date = (DateOnly)ViewData["Date"]; ViewData["Title"] = "Today's Schedule"; }
<div class="d-flex justify-content-between align-items-center mb-3">
  <h2 class="m-0">Today's Schedule (@date)</h2>
  <div class="d-flex gap-2">
  </div>
</div>
<div class="list-group">
  @foreach (var d in Model)
  {
    <div class="list-group-item d-flex justify-content-between align-items-center">
      <div>
        <div class="fw-semibold">@d.Medication?.Name</div>
        <div class="text-muted small">@d.Time · @d.Medication?.DosageDisplay</div>
      </div>
      <div>
        @if (!d.Taken)
        {
          <form method="post" asp-controller="Schedule" asp-action="MarkTaken" asp-route-id="@d.Id" class="d-inline">
            <button class="btn btn-success">Mark taken</button>
          </form>
        }
        else { <span class="badge bg-success">Taken</span> }
      </div>
    </div>
  }
</div>
