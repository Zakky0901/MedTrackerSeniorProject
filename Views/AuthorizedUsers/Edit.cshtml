@model MedTrackerScreensMVC.Models.AuthorizedUser
<h2 class="mb-3">Edit User</h2>
<form method="post"><input type="hidden" asp-for="Id"/>
<div asp-validation-summary="ModelOnly" class="text-danger"></div>
<div class="mb-3"><label class="form-label">Full name</label><input asp-for="FullName" class="form-control" /></div>
<div class="mb-3"><label class="form-label">Relationship</label><select asp-for="RelationshipTypeId" class="form-select" asp-items="@(new SelectList(ViewBag.Relationships, "Id", "Name"))"></select></div>
<div class="row">
  <div class="col-md-6 mb-3"><label class="form-label">Email</label><input asp-for="Email" class="form-control" /></div>
  <div class="col-md-6 mb-3"><label class="form-label">Phone</label><input asp-for="Phone" class="form-control" /></div>
</div>
<div class="d-flex gap-2"><button class="btn btn-primary" type="submit">Save</button><a href="/AuthorizedUsers" class="btn btn-outline-secondary">Cancel</a></div></form>
